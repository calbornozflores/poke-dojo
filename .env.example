# Supabase — global leaderboard + Google auth
# Create a free project at https://supabase.com and fill in these values.
# Rename this file to .env — it is gitignored.

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-publishable-key-here
SUPABASE_SERVICE_KEY=your-secret-key-here

# PostgreSQL connection string — enables global mode (game data persisted to Supabase).
# Get from: Supabase Dashboard → Settings → Database → Connection String → Session pooler URI
# Omit this variable to run locally with SQLite instead.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Max registered players before new sign-ups are blocked.
# Prevents hitting Supabase free-tier storage limits (500 MB).
# Based on storage math: 500 heavy users ≈ 255 MB worst case.
MAX_PLAYERS=500
# ── Supabase setup steps ──────────────────────────────────────────────────────
# 1. supabase.com → New project → copy URL + anon key + service_role key above
# 2. Project Settings → Auth → Providers → Google → enable, add Client ID + Secret
#    (get Google credentials from console.cloud.google.com, OAuth 2.0 client)
#    Authorised redirect URIs in Google Cloud: https://kcjjawhyhazosecmayxu.supabase.co/auth/v1/callback
# 3. Run the SQL below in the Supabase SQL editor to create the required tables:
#
# CREATE TABLE players (
#   id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
#   google_id TEXT UNIQUE NOT NULL,
#   username TEXT UNIQUE NOT NULL,
#   created_at TIMESTAMPTZ DEFAULT NOW()
# );

# CREATE TABLE solo_runs (
#   id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
#   player_id UUID REFERENCES players(id) ON DELETE CASCADE UNIQUE,
#   username TEXT NOT NULL,
#   score INTEGER NOT NULL DEFAULT 0,
#   rounds INTEGER NOT NULL DEFAULT 0,
#   shadow_won_rounds INTEGER NOT NULL DEFAULT 0,
#   created_at TIMESTAMPTZ DEFAULT NOW()
# );
# -- UNIQUE (player_id) enforces one row per player — always the best result.
#
# -- Allow anyone to read leaderboard; only service role can write (FastAPI uses service key)
# ALTER TABLE players ENABLE ROW LEVEL SECURITY;
# ALTER TABLE solo_runs ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "Public read players"   ON players   FOR SELECT USING (true);
# CREATE POLICY "Public read solo_runs" ON solo_runs  FOR SELECT USING (true);
